# EcomProfit Guard — example env
# Backend (backend/.env or root .env when running from backend/)

# Database (SQLite by default)
DATABASE_URL=sqlite+aiosqlite:///./ecomprofit.db

# JWT
SECRET_KEY=your-secret-key-change-in-production

# Google OAuth 2.0 (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URI must match the one in Google Cloud Console and point to frontend
REDIRECT_URI=http://localhost:5173/auth/callback
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Optional
DEBUG=false
DEFAULT_PROFITABILITY_THRESHOLD_PCT=15
FORECAST_MIN_MONTHS_HISTORY=12

# Один фиксированный проект (Google Таблица) на пользователя; в UI нельзя сменить ссылку
STATIC_PROJECT_ENABLED=true
STATIC_SPREADSHEET_ID=1ka36o4ggW0i0ALRhSER6qf_pbGxg2pC6zSSGaF9EE3o
STATIC_SHEET_ACTS=Акты
STATIC_SHEET_COSTS=Затраты
STATIC_SHEET_SPECIALISTS=TL / Специалисты
STATIC_SHEET_METRICS=Метрики
STATIC_PROJECT_NAME=Проект
